Proceso CANTIDADDEMINUTOSAHORASYMINUTOS
	Escribir "PROGRAMA QUE CALCULA HORA Y MINUTOS CON UNA CIERTA CANTIDAD DE MINUTOS"
	Escribir  " DIGITE LA CANTIDAD DE MINUTOS"
	LEER MINUTOS
	HORAS = (MINUTOS / 60)
	MIN_RESTANTES = MINUTOS MOD 60
	Escribir "HORAS: ", HORAS
	ESCRIBIR "MINUTOS: ", MIN_RESTANTES
	FinProceso
